{
  "entities": {
    "User": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "User",
      "type": "object",
      "description": "Represents a user of the MBN school council application, including their profile information, role, and experience points.",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "format": "enum" },
        "xp": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "email", "displayName", "role", "xp", "createdAt", "updatedAt"]
    },
    "Proposal": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Proposal",
      "type": "object",
      "description": "Represents an open announcement.",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "content": { "type": "string" },
        "authorId": { "type": "string" },
        "visibility": { "type": "string", "format": "enum" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "title", "content", "authorId", "visibility", "createdAt", "updatedAt"]
    },
    "MeetingMinute": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "MeetingMinute",
      "type": "object",
      "description": "Represents the official minutes of a meeting.",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "content": { "type": "string" },
        "meetingDate": { "type": "string", "format": "date" },
        "authorId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "title", "content", "meetingDate", "authorId", "createdAt", "updatedAt"]
    },
    "XpTemplate": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "XpTemplate",
      "type": "object",
      "description": "Predefined XP actions that can be applied to students.",
      "properties": {
        "id": { "type": "string" },
        "label": { "type": "string", "description": "The name of the template (e.g., 'Attendance')" },
        "reason": { "type": "string", "description": "The reason recorded in the log." },
        "amount": { "type": "number", "description": "The XP value to add or subtract." },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "label", "reason", "amount", "createdAt", "updatedAt"]
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}",
        "definition": {
          "entityName": "User",
          "schema": { "$ref": "#/backend/entities/User" }
        }
      },
      {
        "path": "/roles_admin/{userId}",
        "definition": {
          "entityName": "User",
          "schema": { "$ref": "#/backend/entities/User" }
        }
      },
      {
        "path": "/roles_council/{userId}",
        "definition": {
          "entityName": "User",
          "schema": { "$ref": "#/backend/entities/User" }
        }
      },
      {
        "path": "/proposals/{proposalId}",
        "definition": {
          "entityName": "Proposal",
          "schema": { "$ref": "#/backend/entities/Proposal" }
        }
      },
      {
        "path": "/meetingMinutes/{meetingMinuteId}",
        "definition": {
          "entityName": "MeetingMinute",
          "schema": { "$ref": "#/backend/entities/MeetingMinute" }
        }
      },
      {
        "path": "/xp_templates/{templateId}",
        "definition": {
          "entityName": "XpTemplate",
          "schema": { "$ref": "#/backend/entities/XpTemplate" }
        }
      }
    ]
  }
}