rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * MBN School Council Firestore Security Rules
     * Role-based access control for Students, Teachers, Council, and Administration.
     */

    // --- Global Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function currentUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function hasRole(role) {
      return isSignedIn() && currentUserData().role == role;
    }

    function isSuperAdmin() {
      return isSignedIn() && (
        currentUserData().isSuperAdmin == true || 
        request.auth.token.email == 'ibrahimezzine09@gmail.com'
      );
    }

    function isAdmin() {
      return isSuperAdmin() || hasRole('administration');
    }

    function isCouncil() {
      return hasRole('council') || isAdmin();
    }

    // --- Collection Rules ---

    match /users/{userId} {
      // Users can read their own profile, Admins can read all.
      allow get: if isOwner(userId) || isAdmin();
      
      // Only Admins can list all users.
      allow list: if isAdmin();
      
      // Allow creation during first-time sign-in.
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      
      // Users can update their own non-sensitive fields.
      // Admins can update everything.
      allow update: if resource != null && (
        isAdmin() || 
        (isOwner(userId) && 
         request.resource.data.role == resource.data.role && 
         request.resource.data.isSuperAdmin == resource.data.isSuperAdmin && 
         request.resource.data.id == resource.data.id)
      );
      
      allow delete: if isAdmin();
    }

    match /announcements/{announcementId} {
      // Anyone signed in can read published announcements.
      // Drafts require ownership or Admin role.
      allow get: if isSignedIn() && (
        resource.data.status == 'Published' || 
        isOwner(resource.data.authorId) || 
        isAdmin()
      );
      
      // List allows based on individual document security.
      allow list: if isSignedIn();

      // Only Council members or Admins can create.
      allow create: if isCouncil() && request.resource.data.authorId == request.auth.uid;

      // Authors can update their own content, Admins can update anything.
      allow update: if resource != null && (
        isAdmin() || 
        (isOwner(resource.data.authorId) && request.resource.data.authorId == resource.data.authorId)
      );

      allow delete: if resource != null && (isOwner(resource.data.authorId) || isAdmin());
    }
  }
}
