rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid)) ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'administration' ||
        request.auth.token.email == 'ibrahimezzine09@gmail.com'
      );
    }

    function isCouncil() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/roles_council/$(request.auth.uid)) ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'council'
      );
    }

    function isStaff() {
      return isAdmin() || isCouncil();
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    match /users/{userId} {
      allow get: if isOwner(userId) || isStaff();
      allow list: if isStaff();
      allow create: if isOwner(userId) || isAdmin();
      allow update: if (isOwner(userId) || isAdmin()) && resource != null;
      allow delete: if isAdmin() && resource != null;
    }

    match /roles_admin/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create, update, delete: if isAdmin();
    }

    match /roles_council/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create, update, delete: if isAdmin();
    }

    match /proposals/{proposalId} {
      allow get: if isStaff() 
                 || resource.data.visibility == 'PUBLIC'
                 || (resource.data.visibility == 'STUDENT' && getUserRole() == 'student')
                 || (resource.data.visibility == 'TEACHER' && getUserRole() == 'teacher');
      allow list: if isStaff()
                  || (isSignedIn() && (getUserRole() == 'student' || getUserRole() == 'teacher'));
      allow create: if isStaff() && request.resource.data.authorId == request.auth.uid;
      allow update: if isStaff() && resource != null && request.resource.data.authorId == resource.data.authorId;
      allow delete: if isStaff() && resource != null;
    }

    match /meetingMinutes/{meetingMinuteId} {
      allow get, list: if isStaff();
      allow create: if isStaff() && request.resource.data.authorId == request.auth.uid;
      allow update: if isStaff() && resource != null && request.resource.data.authorId == resource.data.authorId;
      allow delete: if isStaff() && resource != null;
    }

    match /xp_templates/{templateId} {
      allow read: if isStaff();
      allow create, update, delete: if isAdmin();
    }

    match /users/{userId}/xp_logs/{logId} {
      allow read: if isOwner(userId) || isStaff();
      allow create: if isStaff();
    }
  }
}